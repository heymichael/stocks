# Backend API (Cloud Run service uses this; not needed for frontend dev)
MASSIVE_API_KEY=

# Auth — set VITE_AUTH_BYPASS=true for local dev without Firebase
VITE_AUTH_BYPASS=false
# Port of the haderach-home dev server (for auth redirect at /)
VITE_HOME_DEV_PORT=5173
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
